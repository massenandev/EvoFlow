{
  "name": "evoflow",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "dev:api": "pnpm --filter @evoflow/api dev",
    "dev:mobile": "pnpm --filter @evoflow/mobile start",
    "test": "pnpm --filter @evoflow/api test && pnpm --filter @evoflow/mobile test",
    "test:api": "pnpm --filter @evoflow/api test",
    "test:mobile": "pnpm --filter @evoflow/mobile test",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down"
  }
}
